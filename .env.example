# Copy to `.env` and fill in only what you need.
# Required ONLY for evaluating closed-source target models (evaluation/evaluate.py
# uses python-dotenv). Open-weight VLMs (Qwen3-VL, LLaVA, GLM, ...) need none of these.

# Shared server: restrict the container to your allocated GPUs (HOST indices,
# as shown by nvidia-smi / ndtop). Leave unset/`all` only on a dedicated machine.
# Example for an allocation of GPUs 4,5,6,7:
# NVIDIA_VISIBLE_DEVICES=4,5,6,7

# OpenAI (GPT-4.1-nano / GPT-4o / GPT-5)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Hugging Face token — only if you pull a gated model repo
HF_TOKEN=
